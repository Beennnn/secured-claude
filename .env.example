# Copy to `.env` and fill the value below.
# `.env` is in `.gitignore` and never committed (ADR-0011).

# Anthropic credential — set ONE of these (the entrypoint accepts either) :
#   ANTHROPIC_API_KEY        regular API key,    sk-ant-api03-...
#   CLAUDE_CODE_OAUTH_TOKEN  Claude Code OAuth,  sk-ant-oat01-...
# Get an API key at https://console.anthropic.com/settings/keys
# Or copy your CLAUDE_CODE_OAUTH_TOKEN from `env | grep CLAUDE_CODE` if you
# already use Claude Code locally.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# Optional: principal id used as the secured-claude policy subject.
# Defaults to "claude-code-default" if unset.
# SECURED_CLAUDE_PRINCIPAL=alice@example.com

# Optional: override the broker URL (only useful for non-default deployments).
# SECURED_CLAUDE_BROKER=http://host.docker.internal:8765
