# syntax=docker/dockerfile:1.7
# Claude Code container — runs the official @anthropic-ai/claude-code CLI behind
# the secured-claude policy gate. See ADR-0005 (containerised Claude Code), ADR-0010
# (network egress allowlist), ADR-0012 (defense-in-depth layers L3+L4).
#
# Build :
#   docker buildx build --platform linux/amd64,linux/arm64 \
#     -t secured-claude/claude-code:vX.Y.Z -f Dockerfile.claude-code .
FROM node:22-slim

# Pin OS packages where Debian provides ABI guarantees ; ca-certificates,
# python3, requests are the runtime needs of the secured-claude-hook.
# hadolint ignore=DL3008
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        ca-certificates \
        python3 \
        python3-pip \
        git \
        curl \
        tini \
 && rm -rf /var/lib/apt/lists/*

# Install Python `requests` for the hook script. We use --break-system-packages
# to install in the system site-packages — fine inside a container ; the
# distinction "system Python" vs "user venv" doesn't apply here. The hook
# only needs `requests` ; the broker side keeps its own venv on the host.
RUN pip3 install --no-cache-dir --break-system-packages requests==2.32.5

# Install the official Claude Code CLI globally. Pinning to a tag keeps the
# image reproducible (ADR-0008). Renovate bumps this regularly.
RUN npm install -g --no-audit --no-fund @anthropic-ai/claude-code@latest \
 && npm cache clean --force

# Embed the secured-claude-hook binary. The hook is read-only ; in a
# downgrade attack (attacker tries to overwrite it) the container's read-only
# rootfs (set in docker-compose.yml) prevents the write.
COPY src/secured_claude/hook.py /usr/local/bin/secured-claude-hook
RUN chmod 0755 /usr/local/bin/secured-claude-hook

# Inject the Claude Code settings template + entrypoint that materializes the
# real settings.json from the template at first run.
COPY docker/settings.template.json /etc/secured-claude/settings.template.json
COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod 0755 /entrypoint.sh

# Run as non-root (ADR-0005, L4 hardening). UID/GID 1000 is the conventional
# first user on Debian-derived images.
RUN groupadd -g 1000 agent \
 && useradd -m -u 1000 -g 1000 -s /bin/bash agent \
 && mkdir -p /workspace /home/agent/.claude/projects \
 && chown -R agent:agent /workspace /home/agent
USER agent

WORKDIR /workspace
ENV HOME=/home/agent \
    SECURED_CLAUDE_BROKER=http://host.docker.internal:8765 \
    SECURED_CLAUDE_TIMEOUT=2.0 \
    SECURED_CLAUDE_PRINCIPAL=claude-code-default

# tini is PID 1 so signals are forwarded properly to claude.
ENTRYPOINT ["/usr/bin/tini", "--", "/entrypoint.sh"]
CMD ["claude"]
