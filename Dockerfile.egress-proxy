# syntax=docker/dockerfile:1.7
# Pre-built egress-proxy sidecar — replaces the apk-install-at-boot pattern
# (ADR-0019 v0.2 stop-gap) so the runtime container can be `read_only: true`
# again. Built by .gitlab-ci/build.yml::build:image:egress-proxy via Kaniko,
# signed by publish:cosign-sign-egress-proxy, attached SBOM via
# security:sbom-egress-proxy.
#
# Pinned by digest per ADR-0008 ; Renovate's customManagers regex tracks the
# alpine pin in renovate.json.

FROM alpine:3.20@sha256:d9e853e87e55526f6b2917df91a2115c36dd7c696a35be12163d44e6e2a4b6bc

# tinyproxy runs as the `tinyproxy` user (uid 100 in alpine's package). The
# compose file's read_only:true + tmpfs for /var/log/tinyproxy + /run/tinyproxy
# handles the writable-paths gap. CAP_NET_BIND_SERVICE not needed (port 3128).
RUN apk add --no-cache tinyproxy=1.11.2-r0

# Foreground (-d) for docker-compose process supervision + log streaming.
ENTRYPOINT ["tinyproxy", "-d", "-c", "/etc/tinyproxy/tinyproxy.conf"]
