# syntax=docker/dockerfile:1.7
# Custom cerbos image — wraps cerbos/cerbos:0.42.0 with the project's
# policies + config baked in (ADR-0036). Closes the v0.5.4 smoke:full-stack
# regression caused by the same Docker-in-Docker bind-mount limitation that
# ADR-0035 fixed for dns-filter + egress-proxy.
#
# Production posture per ADR-0001 : Cerbos PDP ; this image is the same
# binary, just with the project's policies pre-loaded so docker-compose
# doesn't need bind-mounts.

FROM cerbos/cerbos:0.42.0@sha256:4302b6ce74fec48f8842bd5fc250b4a7d416fb825e06d86d35c3794ed73182f2

# Bake the project policies + cerbos config. Same `policies/` source as
# the v0.4 bind-mount path. Operators who need a per-deployment override
# add a docker-compose.override.yml with their own bind-mount.
COPY policies /policies
COPY cerbos/config.yaml /etc/cerbos/config.yaml

# Run as non-root (Trivy DS-0002 satisfied). uid 1001 matches what the
# v0.4 docker-compose.yml's `user: "1001:1001"` set ; cerbos/cerbos's
# distroless base supports this — the binary doesn't need root, only
# read access to /policies + /etc/cerbos which we just COPYed as root
# but with mode 0644 by default.
USER 1001:1001

# ENTRYPOINT/CMD inherited from the upstream cerbos/cerbos:0.42.0 image
# (uses /cerbos with --config=/etc/cerbos/config.yaml).
